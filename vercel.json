{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.go",
      "use": "@vercel/go"
    }
  ],
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": "/backend/api/index.go"
    },
    {
      "source": "/api/backend",
      "destination": "/backend/api/index.go"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
